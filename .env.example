# Keep these immutable version tags aligned with Dockerfile/compose.yaml.
PYTHON_IMAGE=python:3.12.13-slim-bookworm
MYSQL_IMAGE=mysql:8.4.10
MINIO_IMAGE=quay.io/minio/minio:RELEASE.2025-09-07T16-13-09Z
MINIO_MC_IMAGE=quay.io/minio/mc:RELEASE.2025-08-13T08-35-41Z

APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
LOG_LEVEL=INFO
API_KEY_ENABLED=true
API_KEY=change-me

MYSQL_HOST=mysql
MYSQL_PORT=3306
MYSQL_DATABASE=video_crawler
MYSQL_USER=video_crawler
MYSQL_PASSWORD=change-me
MYSQL_ROOT_PASSWORD=change-root-me
MYSQL_POOL_SIZE=10
MYSQL_MAX_OVERFLOW=10

MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=video-crawler
MINIO_SECRET_KEY=change-me
MINIO_BUCKET=crawler-raw
MINIO_SECURE=false
RAW_ARTIFACT_RETENTION_DAYS=30
RAW_ARTIFACT_CLEANUP_ENABLED=true
RAW_ARTIFACT_CLEANUP_HOUR_UTC=3

BROWSER_PROFILE_ROOT=/var/lib/video-crawler/browser-profiles
WORKER_ID=worker-1
WORKER_POLL_INTERVAL_SECONDS=2
WORKER_HEARTBEAT_INTERVAL_SECONDS=5
WORKER_STALE_AFTER_SECONDS=30
TASK_TERMINATE_GRACE_SECONDS=5
TASK_KILL_TIMEOUT_SECONDS=10

DEFAULT_VIDEO_LIMIT=100
DEFAULT_MAX_ROOT_COMMENTS=1000
DEFAULT_MAX_RETRIES=3
DEFAULT_TIMED_TEXT_BATCH_SIZE=1000
DEFAULT_VIDEO_DELAY_MIN_SECONDS=1.0
DEFAULT_VIDEO_DELAY_MAX_SECONDS=3.0
DEFAULT_COMMENT_PAGE_DELAY_MIN_SECONDS=0.8
DEFAULT_COMMENT_PAGE_DELAY_MAX_SECONDS=1.5
DEFAULT_REQUEST_TIMEOUT_SECONDS=30
DEFAULT_PAGE_TIMEOUT_SECONDS=60

IDEMPOTENCY_TTL_HOURS=24
